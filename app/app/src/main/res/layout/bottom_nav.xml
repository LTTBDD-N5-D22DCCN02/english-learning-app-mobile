<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:background="@color/primary"
    android:orientation="horizontal"
    android:gravity="center">

    <LinearLayout android:id="@+id/btnNavHome" android:layout_width="0dp"
        android:layout_height="match_parent" android:layout_weight="1"
        android:gravity="center" android:orientation="vertical"
        android:background="?attr/selectableItemBackgroundBorderless">
        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_home" />
    </LinearLayout>

    <LinearLayout android:id="@+id/btnNavSets" android:layout_width="0dp"
        android:layout_height="match_parent" android:layout_weight="1"
        android:gravity="center" android:orientation="vertical"
        android:background="?attr/selectableItemBackgroundBorderless">
        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_folder" />
    </LinearLayout>

    <LinearLayout android:id="@+id/btnNavAdd" android:layout_width="0dp"
        android:layout_height="match_parent" android:layout_weight="1"
        android:gravity="center" android:orientation="vertical"
        android:background="?attr/selectableItemBackgroundBorderless">
        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_add" />
    </LinearLayout>

    <LinearLayout android:id="@+id/btnNavNotif" android:layout_width="0dp"
        android:layout_height="match_parent" android:layout_weight="1"
        android:gravity="center" android:orientation="vertical"
        android:background="?attr/selectableItemBackgroundBorderless">
        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_bell" />
    </LinearLayout>

    <LinearLayout android:id="@+id/btnNavStats" android:layout_width="0dp"
        android:layout_height="match_parent" android:layout_weight="1"
        android:gravity="center" android:orientation="vertical"
        android:background="?attr/selectableItemBackgroundBorderless">
        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_stats" />
    </LinearLayout>

</LinearLayout>