<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back_circle"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1 / 10"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/white" />
    </LinearLayout>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:progress="10"
        android:max="100"
        android:progressTint="@color/primary"
        android:progressBackgroundTint="#E0E0E0" />

    <!-- Flashcard area — weight=1, takes all remaining space -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFlashcard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/white">

            <!-- FRONT -->
            <LinearLayout
                android:id="@+id/layoutFront"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Front"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvCardFront"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="English Word"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvCardIPA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="15sp"
                    android:textColor="#E67E22"
                    android:fontFamily="serif"
                    android:layout_marginTop="6dp" />

                <ImageButton
                    android:id="@+id/btnPlayAudio"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_speaker"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/primary"
                    android:layout_marginTop="10dp" />

                <!-- Ảnh minh họa: nằm dưới nút âm thanh -->
                <ImageView
                    android:id="@+id/ivCardImage"
                    android:layout_width="160dp"
                    android:layout_height="110dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_flashcard_box"
                    android:layout_marginTop="14dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvTapHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="( Tap to flip )"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <!-- BACK -->
            <LinearLayout
                android:id="@+id/layoutBack"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Back"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvCardBackTerm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvCardBackIPA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="#E67E22"
                    android:fontFamily="serif"
                    android:layout_marginTop="4dp" />

                <ImageButton
                    android:id="@+id/btnPlayAudioBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_speaker"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/primary"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="10dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Definition:"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvCardBack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Example:"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvExample"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="( Tap to flip back )"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginTop="10dp" />
            </LinearLayout>

            <!-- Swipe overlays bên trong card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/overlayForgot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|top"
                android:layout_margin="20dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="#F44336"
                app:cardElevation="0dp"
                android:rotation="-12"
                android:alpha="0">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FORGOT"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/overlayRemembered"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|top"
                android:layout_margin="20dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="#4CAF50"
                app:cardElevation="0dp"
                android:rotation="12"
                android:alpha="0">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GOT IT!"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp" />
            </com.google.android.material.card.MaterialCardView>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <!-- Swipe hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← Swipe left: Forgot   |   Swipe right: Remembered →"
        android:textSize="11sp"
        android:textColor="@color/text_hint"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="2dp" />

    <!-- Bottom row: Forgot badge | View Details | Remembered badge (thẳng hàng) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingBottom="4dp"
        android:paddingTop="2dp"
        android:gravity="center_vertical">

        <!-- Forgot badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FFEBEE"
            android:paddingLeft="10dp"
            android:paddingRight="10dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_warning_triangle"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tvForgotBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/10"
                android:textSize="12sp"
                android:textColor="@color/error"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- View Details — flex center giữa 2 badge -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewDetails"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:text="View Details"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            app:backgroundTint="@color/white"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp"
            app:cornerRadius="16dp"
            app:elevation="3dp" />

        <!-- Remembered badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#E8F5E9"
            android:paddingLeft="10dp"
            android:paddingRight="10dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_checklist"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tvRememberedBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/10"
                android:textSize="12sp"
                android:textColor="#2E7D32"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingBottom="16dp"
        android:paddingTop="6dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnForgot"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Forgot"
            android:layout_marginEnd="8dp"
            android:textColor="@color/error"
            app:backgroundTint="#FFCDD2"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_warning_triangle"
            app:iconTint="@color/error"
            app:iconGravity="textStart"
            app:iconSize="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemembered"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Remembered"
            android:layout_marginStart="8dp"
            android:textColor="@color/white"
            app:backgroundTint="@color/success"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_checklist"
            app:iconTint="@color/white"
            app:iconGravity="textStart"
            app:iconSize="18dp" />
    </LinearLayout>
</LinearLayout>