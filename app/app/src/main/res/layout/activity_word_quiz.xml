<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back_circle"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/white" />

        <!-- Tiêu đề set name -->
        <TextView
            android:id="@+id/tvSetName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:ellipsize="end"
            android:maxLines="1" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/white" />
    </LinearLayout>

    <!-- Progress bar + F/T counter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        android:background="@color/background">

        <!-- Progress row: badge di chuyển theo thanh -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="4dp">

            <!-- Progress bar (căn giữa dọc) -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:progress="0"
                android:max="100"
                android:progressDrawable="@drawable/progress_study"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Badge số hiện tại: di chuyển theo % progress -->
            <TextView
                android:id="@+id/tvCurrentNum"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_current_circle"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:translationX="0dp" />

            <!-- Badge tổng: bên phải cố định -->
            <TextView
                android:id="@+id/tvTotalNum"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="10"
                android:textColor="#666666"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_total_circle"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- F / T counter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="2dp">

            <!-- F (Fail) -->
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_warning_triangle"
                app:tint="#E24B4A"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/tvFailCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="F: 0"
                android:textColor="#E24B4A"
                android:textSize="13sp"
                android:layout_marginEnd="20dp" />

            <!-- T (Total answered) -->
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_checklist"
                app:tint="#4FB968"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/tvTotalAnswered"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="T: 0"
                android:textColor="#4FB968"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Content: Question card + Options -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Question card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_question_card"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp"
                android:layout_marginBottom="28dp"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/tvQuestionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose the correct meaning"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="12dp" />

                <!-- Term row: speaker + term + IPA -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/btnPlayAudio"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_speaker"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/primary"
                        android:padding="4dp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/tvQuestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ruler"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/tvQuestionIpa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ˈruːlər/"
                        android:textSize="14sp"
                        android:textColor="@color/status_due"
                        android:fontFamily="serif" />
                </LinearLayout>
            </LinearLayout>

            <!-- Option A -->
            <LinearLayout
                android:id="@+id/btnOption1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_option_default"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="18dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvLabel1"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="A"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_label_circle"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvOption1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Option A"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Option B -->
            <LinearLayout
                android:id="@+id/btnOption2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_option_default"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="18dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvLabel2"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="B"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_label_circle"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvOption2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Option B"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Option C -->
            <LinearLayout
                android:id="@+id/btnOption3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_option_default"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="18dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvLabel3"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="C"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_label_circle"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvOption3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Option C"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Option D -->
            <LinearLayout
                android:id="@+id/btnOption4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_option_default"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="18dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvLabel4"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="D"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_label_circle"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvOption4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Option D"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- NEXT button (ẩn mặc định, hiện sau khi chọn) -->
            <Button
                android:id="@+id/btnNext"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="NEXT"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                android:visibility="gone"
                android:layout_marginTop="8dp"
                app:cornerRadius="24dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>