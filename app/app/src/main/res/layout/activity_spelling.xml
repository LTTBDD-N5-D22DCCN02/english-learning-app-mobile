<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ── Header: back + progress bar + F/T counters ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back_circle"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            app:tint="@color/primary"/>

        <!-- Progress bar (filled) -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="10dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_study"/>

        <!-- F: wrong counter -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="10dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_dialog_alert"
                app:tint="#EF4444"/>
            <TextView
                android:id="@+id/tvWrongCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="F: 0"
                android:textSize="12sp"
                android:textColor="#EF4444"
                android:textStyle="bold"
                android:layout_marginStart="3dp"/>
        </LinearLayout>

        <!-- T: correct counter -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="#10B981"/>
            <TextView
                android:id="@+id/tvCorrectCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="T: 0"
                android:textSize="12sp"
                android:textColor="#10B981"
                android:textStyle="bold"
                android:layout_marginStart="3dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Scrollable content ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Prompt -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type the correct word :"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="14dp"/>

            <!-- Card: image + definition + IPA + speaker -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="#E2E8F0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Image placeholder (shown only if image available) -->
                    <ImageView
                        android:id="@+id/imgCard"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone"/>

                    <!-- Definition -->
                    <TextView
                        android:id="@+id/tvDefinition"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="a narrow, flat object with straight edges you can use to draw straight lines"
                        android:textSize="14sp"
                        android:textColor="#374151"
                        android:padding="16dp"
                        android:gravity="center"/>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F1F5F9"/>

                    <!-- Speaker + IPA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp">

                        <ImageButton
                            android:id="@+id/btnSpeaker"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_speaker"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="4dp"
                            app:tint="@color/primary"/>

                        <TextView
                            android:id="@+id/tvIpa"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="/ˈruːlər/"
                            android:textSize="15sp"
                            android:textColor="@color/status_due"
                            android:textStyle="italic"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Hint button -->
            <Button
                android:id="@+id/btnHint"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="  Hint"
                android:drawableStart="@drawable/ic_hint_bulb"
                android:drawablePadding="8dp"
                android:textSize="15sp"
                android:textColor="#D97706"
                android:textStyle="bold"
                android:background="@drawable/bg_hint_button"
                android:layout_marginBottom="16dp"
                android:letterSpacing="0.02"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.Material3.Button.OutlinedButton"/>

            <!-- Number of letters -->
            <TextView
                android:id="@+id/tvLetterCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Number of letters: 5"
                android:textSize="13sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <!-- Letter boxes container -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/layoutLetterBoxes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

            <!-- Hidden EditText for keyboard input -->
            <EditText
                android:id="@+id/etHiddenInput"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:alpha="0"
                android:inputType="text"
                android:maxLines="1"
                android:imeOptions="actionDone"/>

            <!-- Feedback area (correct/wrong) -->
            <LinearLayout
                android:id="@+id/layoutFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="12dp">

                <!-- Correct feedback -->
                <LinearLayout
                    android:id="@+id/layoutCorrectFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_correct_feedback"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓ Correct !"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#10B981"/>
                </LinearLayout>

                <!-- Correct word (shown after correct) -->
                <TextView
                    android:id="@+id/tvCorrectWord"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="ruler"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#10B981"
                    android:background="@drawable/bg_correct_feedback"
                    android:visibility="gone"/>

                <!-- Wrong feedback: user answer -->
                <LinearLayout
                    android:id="@+id/layoutWrongFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_wrong_feedback"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:id="@+id/tvUserAnswer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="rular ✗"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#EF4444"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Correct answer:"
                        android:textSize="12sp"
                        android:textColor="#EF4444"
                        android:gravity="center"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvCorrectAnswer"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="ruler"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#EF4444"
                        android:background="@drawable/bg_wrong_feedback"/>
                </LinearLayout>
            </LinearLayout>

            <!-- CHECK / NEXT button -->
            <Button
                android:id="@+id/btnCheck"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="CHECK"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                android:letterSpacing="0.08"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
