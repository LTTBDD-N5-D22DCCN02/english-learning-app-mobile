<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/primary"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Filter"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnCloseFilter"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/white" />
    </LinearLayout>

    <!-- Options -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp">

        <TextView android:id="@+id/optAll"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="All" android:textSize="15sp" android:textStyle="bold"
            android:textColor="@color/text_primary" android:gravity="center"
            android:background="@drawable/bg_mode_selected"
            android:layout_marginBottom="4dp" />

        <TextView android:id="@+id/optRemembered"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Remembered" android:textSize="15sp"
            android:textColor="@color/text_secondary" android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginBottom="4dp" />

        <TextView android:id="@+id/optNeedReview"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Need review" android:textSize="15sp"
            android:textColor="@color/text_secondary" android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginBottom="4dp" />

        <TextView android:id="@+id/optNotStudy"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Not study" android:textSize="15sp"
            android:textColor="@color/text_secondary" android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

</LinearLayout>