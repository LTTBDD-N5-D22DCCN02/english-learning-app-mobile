<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Row 1: icon folder + tên bộ + word count + arrow ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- Folder icon nhỏ -->
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_folder"
                android:tint="#94a3b8" />

            <!-- Tên bộ -->
            <TextView
                android:id="@+id/tvSetName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Set name"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1e293b"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Số từ due/new -->
            <TextView
                android:id="@+id/tvWordCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10 words"
                android:textSize="11sp"
                android:textColor="#94a3b8"
                android:layout_marginEnd="4dp" />

            <!-- Arrow → -->
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_down"
                android:rotation="-90"
                android:tint="#94a3b8" />
        </LinearLayout>

        <!-- ── Row 2: subtitle (last reviewed) ─────────────────── -->
        <TextView
            android:id="@+id/tvSetSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last reviewed: yesterday"
            android:textSize="10sp"
            android:textColor="#94a3b8"
            android:paddingHorizontal="12dp"
            android:paddingBottom="6dp" />

        <!-- ── Row 3: progress bar ──────────────────────────────── -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="8dp"
            android:progress="0"
            android:max="100"
            android:progressDrawable="@drawable/progress_study" />

        <!-- ── Row 4: preview từ (chip ngang) ──────────────────── -->
        <LinearLayout
            android:id="@+id/layoutWordPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>