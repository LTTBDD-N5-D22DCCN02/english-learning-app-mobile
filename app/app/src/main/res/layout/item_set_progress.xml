<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Row 1: tên bộ + % -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_folder"
                android:tint="#94a3b8"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tvSetName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Set name"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1e293b"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="75%"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />
        </LinearLayout>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:progress="75"
            android:max="100"
            android:progressDrawable="@drawable/progress_study"
            android:layout_marginBottom="8dp" />

        <!-- Row 3: 3 trạng thái từ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Remembered -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_dot_green"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tvRemembered"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10 nhớ"
                    android:textSize="10sp"
                    android:textColor="@color/status_done" />
            </LinearLayout>

            <!-- Not yet -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_dot_red"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tvNotYet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 chưa nhớ"
                    android:textSize="10sp"
                    android:textColor="@color/status_due" />
            </LinearLayout>

            <!-- Not studied -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_dot_gray"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tvNotStudied"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 chưa học"
                    android:textSize="10sp"
                    android:textColor="#94a3b8" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
