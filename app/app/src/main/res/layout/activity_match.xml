<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ── Header ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="2dp">

        <!-- Progress counter -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#64748B">

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="1/10"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:paddingHorizontal="10dp"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Music icon -->
        <ImageView
            android:id="@+id/btnToggleSound"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_music_note"
            android:layout_marginStart="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#64748B"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Timer icon + badge -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_timer"
            android:layout_marginEnd="6dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#EF4444">

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="90s"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:paddingHorizontal="10dp"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- ── Instruction ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Match the word with its correct meaning"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:gravity="center"
        android:paddingVertical="14dp"
        android:paddingHorizontal="16dp"/>

    <!-- ── Match grid ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingBottom="12dp">

            <!-- Left column: terms -->
            <LinearLayout
                android:id="@+id/layoutLeftColumn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="6dp"/>

            <!-- Right column: definitions -->
            <LinearLayout
                android:id="@+id/layoutRightColumn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- ── SKIP button ── -->
    <Button
        android:id="@+id/btnSkip"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginVertical="12dp"
        android:layout_marginHorizontal="16dp"
        android:text="SKIP"
        android:textSize="13sp"
        android:textColor="#64748B"
        android:backgroundTint="@color/white"
        android:paddingHorizontal="32dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        style="@style/Widget.Material3.Button.OutlinedButton"/>

</LinearLayout>
