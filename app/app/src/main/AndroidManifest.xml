<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.App">

        <activity
            android:name=".controller.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".controller.LoginActivity" />
        <activity android:name=".controller.RegisterActivity" />

        <activity
            android:name=".controller.HomeActivity"
            android:windowSoftInputMode="adjustPan" />

        <activity
            android:name=".controller.FlashCardSetListActivity"
            android:windowSoftInputMode="adjustPan" />

        <activity android:name=".controller.FlashCardSetCreateActivity" />
        <activity android:name=".controller.FlashCardSetEditActivity" />
        <activity android:name=".controller.FlashCardSetOverviewActivity" />
        <activity android:name=".controller.FlashCardSetDetailActivity" />
        <activity android:name=".controller.FlashCardListActivity" />

        <activity
            android:name=".controller.MyClassesActivity"
            android:windowSoftInputMode="adjustPan" />

        <activity
            android:name=".controller.CreateClassActivity"
            android:windowSoftInputMode="adjustPan" />
        <activity android:name=".controller.ClassDetailActivity" />
        <activity
            android:name=".controller.MemberListActivity"
            android:windowSoftInputMode="adjustPan" />
        <activity android:name=".controller.GroupManagementActivity" />
        <activity android:name=".controller.AddMemberActivity" />
        <activity android:name=".controller.ApproveRequestsActivity" />
        <activity
            android:name=".controller.ClassFlashcardSetsActivity"
            android:windowSoftInputMode="adjustPan" />

        <activity
            android:name=".controller.DiscoverClassesActivity"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".controller.ClassSettingActivity"
            android:windowSoftInputMode="adjustPan" />
        <activity android:name=".controller.StudyTodayActivity" android:exported="false" />
        <activity android:name=".controller.StudySetWordsActivity" android:exported="false" />
        <activity android:name=".controller.SpellingActivity" android:exported="false" />
        <activity android:name=".controller.FlashcardStudyActivity" android:exported="false" />
        <activity android:name=".controller.MatchPairActivity" android:exported="false" />
        <activity android:name=".controller.WordQuizActivity" android:exported="false" />
        <activity android:name=".controller.SessionResultActivity" android:exported="false" />
        <activity android:name=".controller.StatisticsActivity" android:exported="false" />
        <activity
            android:name=".controller.FlashCardImportActivity"
            android:exported="false" />

    </application>

</manifest>