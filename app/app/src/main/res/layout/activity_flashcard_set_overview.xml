<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar_common"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#212121"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvPrivacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#212121"
                android:layout_marginBottom="24dp" />

            <!-- Flashcards box — nhấn vào → mở FlashCardSetDetailActivity (danh sách từ) -->
            <LinearLayout
                android:id="@+id/layoutFlashCards"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/bg_flashcard_box"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Flashcards"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#212121" />

                    <TextView
                        android:id="@+id/tvFlashCardCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#757575"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Nút + thêm từ mới → FlashCardListActivity -->
                <ImageButton
                    android:id="@+id/btnAddCard"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_nav_add"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/primary"
                    android:padding="8dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="Add flashcard" />
            </LinearLayout>

            <!-- Review header -->
            <LinearLayout
                android:id="@+id/layoutReviewHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Review"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#212121" />

                <ImageButton
                    android:id="@+id/btnToggleComments"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/arrow_down_float"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#212121" />
            </LinearLayout>

            <!-- Comments list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvComments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="12dp" />

            <!-- Ô nhập comment — chỉ hiện khi PUBLIC -->
            <LinearLayout
                android:id="@+id/layoutAddComment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_comment_input"
                android:paddingStart="12dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etComment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Write a comment..."
                    android:textSize="14sp"
                    android:textColor="#212121"
                    android:textColorHint="#9E9E9E"
                    android:background="@null"
                    android:minLines="1"
                    android:maxLines="4"
                    android:inputType="textMultiLine"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <ImageButton
                    android:id="@+id/btnSendComment"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_send"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/primary"
                    android:padding="6dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/bottom_nav" />
</LinearLayout>