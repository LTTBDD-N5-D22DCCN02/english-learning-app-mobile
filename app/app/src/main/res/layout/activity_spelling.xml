<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back_circle"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/white" />

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/white" />
    </LinearLayout>

    <!-- Progress section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="4dp">

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:progress="0"
                android:max="100"
                android:progressDrawable="@drawable/progress_study"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tvTotalNum"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/tvCurrentNum"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_current_circle"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvTotalNum"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="10"
                android:textColor="#666666"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_total_circle"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- F / T counter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_warning_triangle" app:tint="#E24B4A"
                android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/tvWrongCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="F: 0" android:textColor="#E24B4A" android:textSize="13sp"
                android:layout_marginEnd="20dp" />

            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_checklist" app:tint="#378ADD"
                android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/tvCorrectCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="T: 0" android:textColor="#378ADD" android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Prompt -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type the correct word :"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="12dp"/>

            <!-- Question card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="#E2E8F0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgCard"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvDefinition"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#374151"
                        android:padding="14dp"
                        android:gravity="center"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F1F5F9"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp">

                        <ImageButton
                            android:id="@+id/btnSpeaker"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_speaker"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="4dp"
                            app:tint="@color/primary"/>

                        <TextView
                            android:id="@+id/tvIpa"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="14sp"
                            android:textColor="@color/status_due"
                            android:fontFamily="serif"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Hint box: FEE685 / 913A00 -->
            <LinearLayout
                android:id="@+id/layoutHintBox"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_hint_button"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <!-- Icon bóng đèn: luôn hiện -->
                <ImageView
                    android:id="@+id/ivHintBulb"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_hint_bulb"
                    app:tint="#913A00"
                    android:layout_marginEnd="8dp"/>

                <!-- "Hint" mặc định → dashes sau khi nhấn -->
                <TextView
                    android:id="@+id/tvHintDisplay"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Hint"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#913A00"
                    android:letterSpacing="0.1"
                    android:gravity="center"/>

                <!-- Eye icon: ẩn lúc đầu, hiện sau khi nhấn hint lần 1 -->
                <ImageView
                    android:id="@+id/ivHintEye"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_eye"
                    app:tint="#913A00"
                    android:visibility="gone"/>
            </LinearLayout>

            <!--
                LETTER BOX AREA: nền DFE7EF, chứa "Number of letters" + ô vuông
                → Sau check: đổi nền xanh (đúng) / đỏ (sai) + hiện correct answer nếu sai
            -->
            <LinearLayout
                android:id="@+id/layoutAnswerArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_answer_area"
                android:padding="14dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/tvLetterCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <!-- Letter boxes wrap -->
                <com.estudy.app.utils.WrapFlowLayout
                    android:id="@+id/layoutLetterBoxes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- Correct answer label (ẩn mặc định, hiện khi sai) -->
                <TextView
                    android:id="@+id/tvCorrectAnswerLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Correct answer:"
                    android:textSize="12sp"
                    android:textColor="#FB2C36"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvCorrectAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FB2C36"
                    android:gravity="center"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Hidden EditText for keyboard -->
            <EditText
                android:id="@+id/etHiddenInput"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:alpha="0"
                android:inputType="text"
                android:maxLines="1"
                android:imeOptions="actionDone"/>

            <!-- CHECK / NEXT button -->
            <Button
                android:id="@+id/btnCheck"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="CHECK"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>